{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'github>synthe102/homelab//.renovate/customManagers.json5',
  ],
  packageRules: [
    {
      description: 'Automerge patch and minor updates',
      matchUpdateTypes: ['minor', 'patch'],
      automerge: true,
    },
    {
      description: 'Disable automerge for Talos packages',
      matchPackageNames: ['ghcr.io/siderolabs/talosctl', 'ghcr.io/siderolabs/installer'],
      automerge: false,
    },
  ],
  argocd: {
    managerFilePatterns: [
      '/clusters/k8s-01/apps/.*\\.yaml$/',
    ],
  },
  'helm-values': {
    managerFilePatterns: [
      '/clusters/k8s-01/apps/.*\\.yaml$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/clusters/k8s-01/apps/.*\\.yaml$/',
    ],
  },
}
